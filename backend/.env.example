# Application Settings
APP_NAME=Cloud Cost Calculator
APP_VERSION=0.1.0
ENVIRONMENT=development

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Database
DATABASE_URL=sqlite:///./cloud_cost_calculator.db

# Infracost Cloud Pricing API
INFRACOST_API_KEY=your_api_key_here
INFRACOST_API_URL=https://pricing.api.infracost.io/graphql

# AWS Pricing API (Optional - if using direct API)
AWS_PRICING_API_URL=https://pricing.us-east-1.amazonaws.com

# Azure Pricing API (Optional)
AZURE_PRICING_API_URL=https://prices.azure.com/api/retail/prices

# GCP Pricing API (Optional)
GCP_PRICING_API_URL=https://cloudbilling.googleapis.com/v1/services

# Pricing Data Refresh
PRICING_REFRESH_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS (if needed for frontend)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
